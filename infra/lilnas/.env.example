# Copy to .env and fill in real values before running:
#   docker compose -f infra/lilnas/docker-compose.yml up -d
# .env is gitignored — never commit the real file.

# Image tag to deploy (a git commit SHA, e.g. from a GHCR build), or "latest".
BUDDY_TAG=latest

# Strong random Postgres password. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=changeme

# 64-hex-char key for session cookie encryption. Generate with: openssl rand -hex 32
SESSION_KEY=changeme

# Absolute path on the NAS storage pool that holds pgdata/ and backups/.
# e.g. /srv/dev-disk-by-uuid-XXXX/buddy
BUDDY_DATA_DIR=/srv/dev-disk-by-uuid-XXXX/buddy
